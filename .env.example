# Optional. Provide a MapLibre style URL that supports Korean labels.
# Example (MapTiler): https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_KEY&language=ko
VITE_MAP_STYLE_URL=

# Optional. Custom attribution HTML if your style/tiles require it.
VITE_MAP_ATTRIBUTION_HTML=

# Cloudflare Pages Functions environment variables (set in Cloudflare dashboard, not in Vite .env):
# GEMINI_API_KEY=YOUR_API_KEY_HERE
# GEMINI_MODEL_ID=gemini-2.5-flash

